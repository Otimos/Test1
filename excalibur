--[[
    EstratÃ©gia corrigida v4.4:
    1. Varre workspace em busca de TODOS os ProximityPrompts ativos.
    2. Filtra pelos que tÃªm KeyCode E (padrÃ£o "Mystery Reward / Gotcha").
    3. Teleporta atÃ© o prompt, dispara FireProximityPrompt diretamente
       â€” muito mais confiÃ¡vel que simular tecla via VIM.
    4. Volta Ã  posiÃ§Ã£o anterior para nÃ£o atrapalhar o farm.
]]

-- ServiÃ§o necessÃ¡rio para disparar ProximityPrompt
local ProximityPromptService = game:GetService("ProximityPromptService")

-- Palavras que IDENTIFICAM rewards (whitelist)
local REWARD_ALLOW = {
    "gotcha", "mystery", "reward", "collect", "pickup",
    "chest", "gift", "loot", "prize", "bonus", "crate", "token",
}

-- Palavras que BLOQUEIAM o prompt (blacklist) â€” quest, NPC, etc.
local REWARD_BLOCK = {
    "quest", "mission", "talk", "npc", "shop", "buy", "sell",
    "start", "accept", "trade", "teleport", "warp", "open",
    "enter", "exit", "interact", "speak", "minion", "soldier",
    "boss", "portal", "dungeon", "level", "upgrade",
}

local function textAllowed(text)
    if not text or text == "" then return false end
    local lower = text:lower()
    for _, kw in ipairs(REWARD_BLOCK) do
        if lower:find(kw, 1, true) then return false end
    end
    for _, kw in ipairs(REWARD_ALLOW) do
        if lower:find(kw, 1, true) then return true end
    end
    return false
end

-- Retorna o ProximityPrompt de reward mais prÃ³ximo dentro do raio
local function findNearestRewardPrompt()
    if not Root then return nil, nil, math.huge end

    local bestPrompt, bestPart, bestDist = nil, nil, math.huge

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Enabled
            and obj.KeyboardKeyCode == Enum.KeyCode.E then

            local action = obj.ActionText or ""
            local object = obj.ObjectText or ""

            -- SÃ³ aceita se ActionText OU ObjectText passar no filtro
            if textAllowed(action) or textAllowed(object) then
                local anchor = obj.Parent
                local anchorPart = nil

                if anchor and anchor:IsA("BasePart") then
                    anchorPart = anchor
                elseif anchor then
                    anchorPart = getRoot(anchor)
                end

                if anchorPart then
                    local dist = (Root.Position - anchorPart.Position).Magnitude
                    if dist < CONFIG.CollectRadius and dist < bestDist then
                        bestDist   = dist
                        bestPrompt = obj
                        bestPart   = anchorPart
                    end
                end
            end
        end
    end

    return bestPrompt, bestPart, bestDist
end


-- Dispara o ProximityPrompt de forma segura
local function firePrompt(prompt)
    -- MÃ©todo 1: FireProximityPrompt via serviÃ§o (mais confiÃ¡vel)
    pcall(function()
        fireproximityprompt(prompt)
    end)
    -- MÃ©todo 2: fallback via evento interno do Roblox
    pcall(function()
        prompt:InputHoldBegin()
        task.wait(0.1)
        prompt:InputHoldEnd()
    end)
end

-- Loop dedicado ao collect â€” roda em paralelo ao farm
local function collectLoop()
    while CONFIG.AutoCollect do
        task.wait(CONFIG.CollectDelay)

        if not refreshChar() or Hum.Health <= 0 then
            continue
        end

        local prompt, part, dist = findNearestRewardPrompt()

        if prompt and part then
            local prevPos = Root.CFrame

            -- Teleporta para bem perto do reward (dentro do MaxActivationDistance)
            local maxDist = prompt.MaxActivationDistance or 10
            if dist > (maxDist - 1) then
                teleportTo(part.Position)
                task.wait(0.12)
            end

            -- Dispara o prompt diretamente
            firePrompt(prompt)
            task.wait(0.2)

            rewardCount += 1

            -- Volta ao farm se estava ativo
            if farmActive and currentTarget then
                Root.CFrame = prevPos
            end
        end
    end
end

-- Inicia o loop de collect assim que o script Ã© executado
task.spawn(collectLoop)

-- ==========================================
--         LOOP PRINCIPAL (FARM)
-- ==========================================

local function farmLoop()
    while farmActive do
        if not refreshChar() or Hum.Health <= 0 then
            task.wait(2)
            continue
        end

        local target = findTarget()

        if target then
            currentTarget = target
            local root = getRoot(target)
            local hum  = target:FindFirstChildOfClass("Humanoid")

            if root and hum and hum.Health > 0 then
                teleportTo(root.Position)
                task.wait(0.06)

                clickM1()

                local now = tick()
                if CONFIG.SkillZ and (now - lastZ) >= CONFIG.SkillZDelay then
                    pressKey(Enum.KeyCode.Z)
                    lastZ = now
                end
                if CONFIG.SkillX and (now - lastX) >= CONFIG.SkillXDelay then
                    pressKey(Enum.KeyCode.X)
                    lastX = now
                end
                if CONFIG.SkillC and (now - lastC) >= CONFIG.SkillCDelay then
                    pressKey(Enum.KeyCode.C)
                    lastC = now
                end
                if CONFIG.SkillV and (now - lastV) >= CONFIG.SkillVDelay then
                    pressKey(Enum.KeyCode.V)
                    lastV = now
                end
                if CONFIG.SkillR and (now - lastR) >= CONFIG.SkillRDelay then
                    pressKey(Enum.KeyCode.R)
                    lastR = now
                end
            end
        else
            currentTarget = nil
            task.wait(1)
        end

        task.wait(CONFIG.AttackDelay)
    end
    currentTarget = nil
end

