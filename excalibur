-- Encontra o botão de dificuldade pelo nome do Frame filho
local function findRaidDiffButton(modeName)
    local PlayerGui = LP.PlayerGui
    for _, obj in ipairs(PlayerGui:GetDescendants()) do
        -- Estrutura: ContentButten > Button > [modeName]
        if obj.Name == modeName and obj:IsA("Frame") then
            local parent = obj.Parent -- Frame "Button"
            if parent and parent.Name == "Button" then
                local grandParent = parent.Parent -- Frame "ContentButten"
                if grandParent and grandParent.Name == "ContentButten" then
                    return grandParent -- clica no ContentButten (é o botão real)
                end
            end
        end
    end
    return nil
end

-- Encontra o botão Start do Raid
local function findRaidStartButton()
    local PlayerGui = LP.PlayerGui
    for _, obj in ipairs(PlayerGui:GetDescendants()) do
        if (obj:IsA("TextButton") or obj:IsA("ImageButton")) and obj.Visible then
            local t = obj.Text or ""
            if t:lower():find("start") then
                return obj
            end
        end
    end
    -- Fallback: busca por nome
    for _, obj in ipairs(PlayerGui:GetDescendants()) do
        if obj.Name == "Start" or obj.Name == "StartBtn" or obj.Name == "StartButton" then
            return obj
        end
    end
    return nil
end

-- Simula clique num objeto GUI
local function fireGuiClick(obj)
    if not obj then return false end
    -- Tenta MouseButton1Click primeiro
    local ok = pcall(function()
        obj.MouseButton1Click:Fire()
    end)
    if not ok then
        -- Fallback: clique por posição central do objeto
        pcall(function()
            local pos = obj.AbsolutePosition
            local size = obj.AbsoluteSize
            local cx = pos.X + size.X / 2
            local cy = pos.Y + size.Y / 2
            VIM:SendMouseMoveEvent(cx, cy, game)
            task.wait(0.05)
            VIM:SendMouseButtonEvent(cx, cy, 0, true,  game, 1)
            task.wait(0.05)
            VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
        end)
    end
    return true
end

local function selectRaidMode(mode)
    local btn = findRaidDiffButton(mode)
    if btn then
        fireGuiClick(btn)
        selectedRaidMode = mode
        raidStatusText = "✅ Modo: " .. mode
        print("[Raid] Modo selecionado: " .. mode)
    else
        -- Fallback por posição de tela (PC)
        local pos = RAID_CONFIG.Positions[mode]
        if pos then
            pcall(function()
                VIM:SendMouseMoveEvent(pos.X, pos.Y, game)
                task.wait(0.05)
                VIM:SendMouseButtonEvent(pos.X, pos.Y, 0, true,  game, 1)
                task.wait(0.05)
                VIM:SendMouseButtonEvent(pos.X, pos.Y, 0, false, game, 1)
            end)
            raidStatusText = "✅ Modo: " .. mode .. " (pos)"
            print("[Raid] Modo selecionado via posição: " .. mode)
        else
            warn("[Raid] Botão não encontrado: " .. mode)
