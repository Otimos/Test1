local function getRoot(model)
    return model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("Root")
        or model:FindFirstChildOfClass("BasePart")
end

local function trackMobDeath(model, hum)
    if not hum or connectedHums[hum] then return end
    connectedHums[hum] = true
    hum.Died:Connect(function()
        if not trackedDeaths[model] then
            trackedDeaths[model] = true
            killCount += 1
        end
    end)
    model.AncestryChanged:Connect(function(_, parent)
        if parent == nil and not trackedDeaths[model] then
            if hum.Health <= 0 then
                trackedDeaths[model] = true
                killCount += 1
            end
        end
    end)
end

local function findTarget(forceAny)
    local ES = workspace:FindFirstChild("EnemyService")
    if not ES or not Root then return nil end
    local best, bestDist = nil, math.huge
    local filterMob = (not forceAny) and CONFIG.SelectedMob or nil
    for _, model in ipairs(ES:GetChildren()) do
        local hum  = model:FindFirstChildOfClass("Humanoid")
        local root = getRoot(model)
        if not hum or not root or hum.Health <= 0 then continue end
        if filterMob then
            local fullName = model.Name
            local realName = fullName:match("%]%s*(.+)$") or fullName
            if realName ~= filterMob and fullName ~= filterMob then continue end
        end
        if hum then trackMobDeath(model, hum) end
        local dist = (Root.Position - root.Position).Magnitude
        if dist < bestDist then bestDist = dist; best = model end
    end
    return best
end

