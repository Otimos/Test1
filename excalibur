--    DETECÇÃO AUTOMÁTICA DE MOBS/BOSSES
-- ==========================================
local function scanMobList()
    local ES = workspace:FindFirstChild("EnemyService")
    if not ES then return {} end
    local seen = {}
    for _, model in ipairs(ES:GetChildren()) do
        local realName = model.Name:match("%]%s*(.+)$") or model.Name
        if realName and realName ~= "" then
            local hum = model:FindFirstChildOfClass("Humanoid")
            local hp  = hum and hum.MaxHealth or 0
            if not seen[realName] or hp > seen[realName] then
                seen[realName] = hp
            end
        end
    end
    local bosses, mobs = {}, {}
    for name, maxHP in pairs(seen) do
        local isBoss = KNOWN_BOSSES[name] or (maxHP >= BOSS_HP_THRESHOLD)
        if isBoss then table.insert(bosses, name)
        else           table.insert(mobs,   name) end
    end
    table.sort(bosses); table.sort(mobs)
    local result = {}
    for _, n in ipairs(bosses) do table.insert(result, { name = n, boss = true  }) end
    for _, n in ipairs(mobs)   do table.insert(result, { name = n, boss = false }) end
    return result
end

