local function getRoot(model)
    return model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("Root")
        or model:FindFirstChildOfClass("BasePart")
end

local function findTarget()
    local ES = workspace:FindFirstChild("EnemyService")
    if not ES or not Root then return nil end

    local best, bestDist = nil, math.huge

    for _, model in ipairs(ES:GetChildren()) do
        if CONFIG.SelectedMob then
            local realName = model.Name:match("%]%s*(.+)$") or model.Name
            if realName ~= CONFIG.SelectedMob then
                continue
            end
        end

        local hum  = model:FindFirstChildOfClass("Humanoid")
        local root = getRoot(model)
        if hum and root and hum.Health > 0 then
            local dist = (Root.Position - root.Position).Magnitude
            if dist < bestDist then
                bestDist = dist
                best = model
            end
        end
    end
    return best
end

