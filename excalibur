local function getSpawnPart(spawnName)
    local spawnContainer = workspace:FindFirstChild("World")
        and workspace.World:FindFirstChild("Spawn")
        and workspace.World.Spawn:FindFirstChild("Spawn")
    if spawnContainer then
        local part = spawnContainer:FindFirstChild(spawnName)
        if part and part:IsA("BasePart") then return part end
        if part then
            local bp = part:FindFirstChildOfClass("BasePart")
            if bp then return bp end
            if part:IsA("SpawnLocation") then return part end
        end
    end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == spawnName and (obj:IsA("BasePart") or obj:IsA("SpawnLocation")) then
            return obj
        end
    end
    return nil
end

local function getIslandPart(islandName)
    local islandContainer = workspace:FindFirstChild("World")
        and workspace.World:FindFirstChild("Island")
        and workspace.World.Island:FindFirstChild("Island")
    if islandContainer then
        local folder = islandContainer:FindFirstChild(islandName)
        if folder then
            local bp = folder:FindFirstChildOfClass("BasePart")
            if bp then return bp end
            for _, d in ipairs(folder:GetDescendants()) do
                if d:IsA("BasePart") then return d end
            end
        end
    end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == islandName and obj:IsA("BasePart") then
            return obj
        end
    end
    return nil
end

