-- Teleporta para área do Raid, seleciona modo e dá start
local function autoStartRaid(mode)
    mode = mode or selectedRaidMode
    raidStatusText = "🚀 Teleportando..."
    print("[Raid] Teleportando para o Raid...")

    -- 1. Teleporta
    if not refreshChar() or not Root then
        raidStatusText = "❌ Sem personagem!"
        return
    end
    Root.CFrame = CFrame.new(RAID_CONFIG.TeleportPos + Vector3.new(0, 4, 0))

    -- 2. Aguarda GUI do Raid abrir
    raidStatusText = "⏳ Aguardando GUI..."
    task.wait(RAID_CONFIG.DelayAfterTP)

    -- 3. Seleciona o modo
    raidStatusText = "🎯 Selecionando " .. mode .. "..."
    selectRaidMode(mode)
    task.wait(RAID_CONFIG.DelayAfterMode)

    -- 4. Clica em Start
    raidStatusText = "▶ Clicando Start..."
    clickRaidStart()
    task.wait(RAID_CONFIG.DelayAfterStart)

    raidStatusText = "✅ Raid " .. mode .. " iniciado!"
end

-- ==========================================
--    AUTO COLLECT REWARDS
-- ==========================================
local REWARD_ALLOW = {
    "gotcha","mystery","reward","collect","pickup",
    "chest","gift","loot","prize","bonus","crate","token"
}
local REWARD_BLOCK = {
    "quest","mission","talk","npc","shop","buy","sell","start",
    "accept","trade","teleport","warp","open","enter","exit",
    "interact","speak","minion","soldier","boss","portal","dungeon",
    "level","upgrade"
}

local function textAllowed(text)
    if not text or text == "" then return false end
    local lower = text:lower()
    for _, kw in ipairs(REWARD_BLOCK) do if lower:find(kw, 1, true) then return false end end
    for _, kw in ipairs(REWARD_ALLOW) do if lower:find(kw, 1, true) then return true  end end
    return false
end

local function findNearestRewardPrompt()
    if not Root then return nil, nil, math.huge end
    local bestPrompt, bestPart, bestDist = nil, nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Enabled
            and obj.KeyboardKeyCode == Enum.KeyCode.E then
            local action = obj.ActionText or ""
            local object = obj.ObjectText or ""
            if textAllowed(action) or textAllowed(object) then
                local anchor = obj.Parent
                local anchorPart = anchor and (anchor:IsA("BasePart") and anchor or getRoot(anchor))
                if anchorPart then
                    local dist = (Root.Position - anchorPart.Position).Magnitude
                    if dist < CONFIG.CollectRadius and dist < bestDist then
                        bestDist = dist; bestPrompt = obj; bestPart = anchorPart
                    end
                end
            end
        end
    end
    return bestPrompt, bestPart, bestDist
end

local function firePrompt(prompt)
    pcall(function() fireproximityprompt(prompt) end)
    pcall(function() prompt:InputHoldBegin(); task.wait(0.1); prompt:InputHoldEnd() end)
end

local function collectLoop()
    if collectActive then return end
    collectActive = true
    while collectActive and CONFIG.AutoCollect do
        task.wait(CONFIG.CollectDelay)
        if not refreshChar() or Hum.Health <= 0 then continue end
        local prompt, part, dist = findNearestRewardPrompt()
        if prompt and part then
            local prevPos = Root.CFrame
            local maxDist = prompt.MaxActivationDistance or 10
            if dist > (maxDist - 1) then teleportTo(part.Position); task.wait(0.12) end
            firePrompt(prompt)
            task.wait(0.2)
            rewardCount += 1
            if farmActive and currentTarget then Root.CFrame = prevPos end
        end
    end
    collectActive = false
end

if CONFIG.AutoCollect then task.spawn(collectLoop) end

-- ==========================================
--         LOOP PRINCIPAL (FARM)
-- ==========================================
local function farmLoop()
    while farmActive do
        if not refreshChar() or Hum.Health <= 0 then task.wait(2); continue end

        local target = findTarget(false)

        if target then
            farmStatusText = "⚔️ Atacando: " .. (CONFIG.SelectedMob or "Qualquer um")
        elseif CONFIG.SelectedMob then
            farmStatusText = "⏳ Aguardando " .. CONFIG.SelectedMob .. "..."
        else
            farmStatusText = "🔍 Procurando mobs..."
        end

        if target then
            currentTarget = target
            local root = getRoot(target)
            local hum  = target:FindFirstChildOfClass("Humanoid")
            if hum then trackMobDeath(target, hum) end

            local stillValid = root and hum and hum.Health > 0
                and target.Parent ~= nil

            if stillValid then
                teleportTo(root.Position)
                task.wait(0.06)

                if hum.Health > 0 and target.Parent ~= nil then
                    clickM1()
                    local now = tick()
                    if CONFIG.SkillZ and (now-lastZ) >= CONFIG.SkillZDelay then pressKey(Enum.KeyCode.Z); lastZ=now end
                    if CONFIG.SkillX and (now-lastX) >= CONFIG.SkillXDelay then pressKey(Enum.KeyCode.X); lastX=now end
                    if CONFIG.SkillC and (now-lastC) >= CONFIG.SkillCDelay then pressKey(Enum.KeyCode.C); lastC=now end
                    if CONFIG.SkillV and (now-lastV) >= CONFIG.SkillVDelay then pressKey(Enum.KeyCode.V); lastV=now end
                    if CONFIG.SkillR and (now-lastR) >= CONFIG.SkillRDelay then pressKey(Enum.KeyCode.R); lastR=now end
                else
                    currentTarget = nil
                end
            else
                currentTarget = nil
            end
        else
            currentTarget = nil
            if not CONFIG.SelectedMob then
                farmStatusText = "🔍 Procurando mobs..."
            end
            pcall(function()
                VIM:SendMouseButtonEvent(0, 0, 0, false, game, 1)
            end)
            task.wait(0.15)
        end
        task.wait(CONFIG.AttackDelay)
    end
    currentTarget = nil
    farmStatusText = "Inativo"
end

